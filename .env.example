# OpenAI — shared API key and fallback defaults
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1024

# Per-role model configuration
# Each node uses its own model. Override any value here; unset = use the default in config.py.
#
# Role          Default model   Purpose
# -----------   -------------   -----------------------------------------------
# ROUTER        gpt-4o-mini     Fast intent classification (low cost, low latency)
# WISMO         gpt-4o          Tool calling + structured order data parsing
# RETURNS       gpt-4o          Eligibility reasoning + tool calling
# REFUNDS       gpt-4o          Refund-state reasoning + tool calling
# RESPONDER     gpt-4o          Highest-quality customer-facing reply generation
ROUTER_MODEL=gpt-4o-mini
ROUTER_TEMPERATURE=0.0
ROUTER_MAX_TOKENS=256

WISMO_MODEL=gpt-4o
WISMO_TEMPERATURE=0.0
WISMO_MAX_TOKENS=1024

RETURNS_MODEL=gpt-4o
RETURNS_TEMPERATURE=0.0
RETURNS_MAX_TOKENS=1024

REFUNDS_MODEL=gpt-4o
REFUNDS_TEMPERATURE=0.0
REFUNDS_MAX_TOKENS=1024

RESPONDER_MODEL=gpt-4o
RESPONDER_TEMPERATURE=0.2
RESPONDER_MAX_TOKENS=1024

# escalation — empathetic handoff message when routing to a human agent
ESCALATION_MODEL=gpt-4o-mini
ESCALATION_TEMPERATURE=0.3
ESCALATION_MAX_TOKENS=512

# off_topic — natural contextual refusal for out-of-scope or harmful requests
OFF_TOPIC_MODEL=gpt-4o-mini
OFF_TOPIC_TEMPERATURE=0.3
OFF_TOPIC_MAX_TOKENS=256

# Ollama (local inference)
# Set USE_OLLAMA=true to route ALL LLM calls to a local Ollama server instead of OpenAI.
# When enabled, update each {ROLE}_MODEL above to the Ollama model you have pulled.
# OLLAMA_BASE_URL defaults to http://localhost:11434 — change only if Ollama runs elsewhere.
#
# Example Ollama model names: llama3.2, llama3.1, mistral, gemma3, qwen2.5, phi4
#
# Quick start:
#   ollama pull llama3.2
#   USE_OLLAMA=true
#   ROUTER_MODEL=llama3.2
#   WISMO_MODEL=llama3.2
#   RETURNS_MODEL=llama3.2
#   REFUNDS_MODEL=llama3.2
#   RESPONDER_MODEL=llama3.2
#   ESCALATION_MODEL=llama3.2
#   OFF_TOPIC_MODEL=llama3.2
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434

# Supabase
# Service role key is required — it bypasses Row Level Security so the backend
# agent can read/write all tables (orders, customers, rma_records, tickets, etc.)
# without per-user RLS restrictions. Never expose this key client-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Observability — LangSmith / Langfuse
# Set OBSERVABILITY_ENABLED=false to fully disable all tracing (no network calls to LangSmith).
# Set to true and provide API keys to enable full observability.
OBSERVABILITY_ENABLED=true

# LangSmith
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=customer-support-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LangChain auto-tracing for LangGraph (requires OBSERVABILITY_ENABLED=true)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=customer-support-agent

# Business Rules
RETURN_WINDOW_DAYS=30
ESCALATION_REFUND_THRESHOLD=500
MAX_AUTO_RETRIES=3
FRAUD_SCORE_THRESHOLD=0.7

# App
APP_TITLE=Customer Support Agent
APP_DEBUG=false
LOG_LEVEL=INFO
